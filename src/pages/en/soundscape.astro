---
import Layout from '../../layouts/Layout.astro';

const sounds = [
  {
    file: 'taichung-green-museumbrary-crickets.mp3',
    location: 'Taichung Green Museumbrary',
    description: 'Evening cricket chorus',
    contributor: 'bugnimusic',
    date: '2026-03',
    icon: '🦗',
  },
  {
    file: 'taipei-nangang-garbage-truck-melody-maidens-prayer.mp3',
    location: 'Taipei Nangang',
    description: "Garbage truck melody (Maiden's Prayer)",
    contributor: 'x1001000',
    date: '2021-03',
    icon: '🚛',
  },
];

const wishlist = [
  { icon: '🚛', text: 'Garbage truck melodies (regional variations)' },
  { icon: '🏯', text: 'Temple Beiguan drums' },
  { icon: '🌊', text: 'East coast waves' },
  { icon: '🏙️', text: 'Night market vendors' },
  { icon: '🐦', text: 'Mountain birdsong' },
  { icon: '🦗', text: 'Insect choruses across Taiwan' },
  { icon: '🚂', text: 'Train station jingles' },
];
---

<!--
  Phase 6 page migration #1: en/soundscape.astro
  ──────────────────────────────────────────────
  - Scoped <style> removed entirely (~190 lines CSS deleted)
  - Single-column reading layout, olive-green accent theme (#ABC468)
  - Note: the zh-TW version (src/pages/soundscape.astro) has a
    different design (green #065f46, larger serif title). The two
    pages are translations but not style-identical, so they're
    migrated independently.
-->
<Layout
  title="Taiwan Soundscape — Taiwan.md"
  description="Discover Taiwan through your ears — a field recording collection featuring crickets, garbage trucks, temple festivals, ocean waves, and other uniquely Taiwanese sounds"
  lang="en"
>
  <div class="mx-auto max-w-[900px] px-6 pb-16 pt-0">
    <section class="py-12 text-center">
      <div>
        <p
          class="mb-2 text-[0.9rem] uppercase tracking-[0.15em] text-[#ABC468]"
        >
          🎧 Soundscape
        </p>
        <h1 class="my-[0.3rem] text-[2.8rem] max-[600px]:text-[2rem]">
          Taiwan Soundscape
        </h1>
        <p class="mt-[0.8rem] text-[1.15rem] leading-[1.8] text-[#a1a1aa]">
          Some stories are best told through ears.
        </p>
        <p class="mt-4 text-[0.85rem] tracking-[0.1em] text-[#52525b]">
          {sounds.length} recordings collected
        </p>
      </div>
    </section>

    <section>
      <div class="mb-12">
        <h2 class="mb-4 text-[1.5rem]">🎙️ Sound Library</h2>
        <div class="flex flex-col gap-[1.2rem]">
          {
            sounds.map((sound) => (
              <div class="rounded-xl border border-white/[0.08] bg-white/[0.03] p-6 transition-colors duration-200 hover:border-[rgba(171,196,104,0.3)]">
                <div class="mb-[0.8rem] text-[2rem]">{sound.icon}</div>
                <div>
                  <h3 class="m-0 mb-[0.3rem] text-[1.2rem]">
                    {sound.location}
                  </h3>
                  <p class="m-0 mb-[0.8rem] text-[#d4d4d8]">
                    {sound.description}
                  </p>
                  <div class="mb-4 flex items-center gap-4 text-[0.85rem]">
                    <a
                      href={`https://github.com/${sound.contributor}`}
                      target="_blank"
                      rel="noopener"
                      class="text-[#ABC468] no-underline hover:underline"
                    >
                      @{sound.contributor}
                    </a>
                    <span class="text-[#52525b]">{sound.date}</span>
                  </div>
                </div>
                <audio controls preload="none" class="h-10 w-full rounded-lg">
                  <source
                    src={`/assets/sounds/${sound.file}`}
                    type="audio/mpeg"
                  />
                </audio>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section>
      <div class="mb-12">
        <h2 class="mb-4 text-[1.5rem]">📋 Wishlist</h2>
        <p class="mb-[1.2rem] text-[#a1a1aa]">
          These are the Taiwan soundscapes we'd love to collect. If you happen
          to have one nearby, record it and contribute!
        </p>
        <div
          class="grid grid-cols-[repeat(auto-fill,minmax(260px,1fr))] gap-[0.8rem]"
        >
          {
            wishlist.map((item) => (
              <div class="flex items-center gap-[0.8rem] rounded-lg border border-white/[0.06] bg-white/[0.02] p-4">
                <span class="flex-shrink-0 text-[1.5rem]">{item.icon}</span>
                <p class="m-0 text-[#d4d4d8]">{item.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section>
      <div class="mb-12 py-8 text-center">
        <h2 class="mb-4 text-[1.5rem]">🎤 Contribute Your Recordings</h2>
        <p
          class="mb-6 leading-[1.8] text-[#a1a1aa] [&>a:not(.cta-btn)]:text-[#ABC468]"
        >
          Record 30 seconds to 2 minutes of Taiwan soundscape with your phone,
          convert to MP3, and open a PR.<br />
          Not familiar with GitHub? Just
          <a href="mailto:cheyu.wu@monoame.com">email us</a> with the recording and
          location description.
        </p>
        <div
          class="mb-8 flex flex-wrap justify-center gap-6 max-[600px]:flex-col max-[600px]:items-center"
        >
          <div class="flex items-center gap-2 text-[0.95rem] text-[#d4d4d8]">
            <span
              class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[rgba(171,196,104,0.15)] text-[0.85rem] font-semibold text-[#ABC468]"
              >1</span
            > Record the sound (30s – 2min)
          </div>
          <div class="flex items-center gap-2 text-[0.95rem] text-[#d4d4d8]">
            <span
              class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[rgba(171,196,104,0.15)] text-[0.85rem] font-semibold text-[#ABC468]"
              >2</span
            > Convert to MP3 (128kbps+)
          </div>
          <div class="flex items-center gap-2 text-[0.95rem] text-[#d4d4d8]">
            <span
              class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-[rgba(171,196,104,0.15)] text-[0.85rem] font-semibold text-[#ABC468]"
              >3</span
            > Open a PR or email us
          </div>
        </div>
        <a
          href="/en/contribute"
          class="cta-btn inline-block rounded-lg border border-[rgba(171,196,104,0.3)] bg-[rgba(171,196,104,0.12)] px-8 py-3 text-[0.95rem] text-[#ABC468] no-underline transition-all duration-200 hover:border-[rgba(171,196,104,0.5)] hover:bg-[rgba(171,196,104,0.2)]"
        >
          Go to Contribution Page →
        </a>
      </div>
    </section>
  </div>
</Layout>
