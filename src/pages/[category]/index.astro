---
import { readdir, readFile } from 'fs/promises';
import { resolve, join, basename } from 'path';
import matter from 'gray-matter';
import { categoryConfig, type CategoryKey } from '../../utils/categoryConfig';

export async function getStaticPaths() {
  const categories = Object.keys(categoryConfig);

  // 類別對應到資料夾名稱
  const categoryMapping: Record<string, string> = {
    'history': 'History',
    'geography': 'Geography', 
    'culture': 'Culture',
    'food': 'Food',
    'art': 'Art',
    'music': 'Music',
    'technology': 'Technology',
    'nature': 'Nature',
    'people': 'People',
    'society': 'Society',
    'economy': 'Economy',
    'lifestyle': 'Lifestyle'
  };

  const paths = [];

  for (const category of categories) {
    const folderName = categoryMapping[category];
    const articles = [];

    try {
      // 中文版本
      const zhFolderPath = resolve(process.cwd(), 'knowledge', folderName);
      try {
        const zhFiles = await readdir(zhFolderPath);
        const zhMarkdownFiles = zhFiles.filter(file => file.endsWith('.md') && !file.startsWith('_'));
        
        for (const file of zhMarkdownFiles) {
          const filePath = join(zhFolderPath, file);
          const fileContent = await readFile(filePath, 'utf-8');
          const { data: frontmatter } = matter(fileContent);
          
          const slug = basename(file, '.md');
          articles.push({
            slug: slug,
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            status: frontmatter.status || '',
            readingTime: frontmatter.readingTime || null,
            date: frontmatter.date || null,
            featured: frontmatter.featured || false,
            lang: 'zh-TW'
          });
        }
      } catch (err) {
        // No Chinese folder, continue
      }

      // 英文版本
      const enFolderPath = resolve(process.cwd(), 'knowledge', 'en', folderName);
      try {
        const enFiles = await readdir(enFolderPath);
        const enMarkdownFiles = enFiles.filter(file => file.endsWith('.md') && !file.startsWith('_'));
        
        for (const file of enMarkdownFiles) {
          const filePath = join(enFolderPath, file);
          const fileContent = await readFile(filePath, 'utf-8');
          const { data: frontmatter } = matter(fileContent);
          
          const slug = basename(file, '.md');
          articles.push({
            slug: slug,
            title: frontmatter.title || slug,
            description: frontmatter.description || '',
            status: frontmatter.status || '',
            readingTime: frontmatter.readingTime || null,
            date: frontmatter.date || null,
            featured: frontmatter.featured || false,
            lang: 'en'
          });
        }
      } catch (err) {
        // No English folder, continue
      }

    } catch (err) {
      // Category folder doesn't exist, continue
    }

    // Only show Chinese articles on main category pages
    const zhArticles = articles.filter(a => a.lang === 'zh-TW');
    
    // Read Hub content (the _*Hub.md file)
    let hubContent = '';
    try {
      const hubFolder = resolve(process.cwd(), 'knowledge', folderName);
      const hubFiles = await readdir(hubFolder);
      const hubFile = hubFiles.find(f => f.startsWith('_') && f.includes('Hub'));
      if (hubFile) {
        const hubPath = join(hubFolder, hubFile);
        const hubRaw = await readFile(hubPath, 'utf-8');
        const { content } = matter(hubRaw);
        // Remove the first H1 line (we already have the hero title)
        hubContent = content.replace(/^#\s+.+\n/, '').trim();
      }
    } catch {}

    paths.push({
      params: { category },
      props: { 
        categoryInfo: categoryConfig[category as CategoryKey],
        category,
        hubContent,
        articles: zhArticles.sort((a, b) => {
          if (a.featured && !b.featured) return -1;
          if (!a.featured && b.featured) return 1;
          return a.title.localeCompare(b.title);
        })
      }
    });
  }

  return paths;
}

import Layout from '../../layouts/Layout.astro';
import { getCategoryConfig } from '../../utils/categoryConfig';

import { marked } from 'marked';
const { categoryInfo, category, hubContent, articles } = Astro.props;

// Load economic data for economy category
let taiexData: any[] = [];
let cpiData: any[] = [];
let salaryData: any[] = [];
let housingData: any[] = [];
if (category === 'economy') {
  const [taiexJson, cpiJson, salaryJson, housingJson] = await Promise.all([
    import('../../data/taiex-yearly.json'),
    import('../../data/taiwan-cpi.json'),
    import('../../data/taiwan-salary.json'),
    import('../../data/taiwan-housing.json'),
  ]);
  taiexData = taiexJson.data;
  cpiData = cpiJson.data;
  salaryData = salaryJson.data;
  housingData = housingJson.data;
}

// Convert [[wikilinks]] to HTML links before marked parsing
function resolveWikilinks(md: string, currentCategory: string): string {
  if (!md) return md;
  // [[Page|Display Text]] or [[Page]]
  return md.replace(/\[\[([^\]|]+?)(?:\|([^\]]+?))?\]\]/g, (_, target, display) => {
    const label = display || target;
    // Check if it's a Hub link (starts with _)
    if (target.startsWith('_')) {
      const catName = target.replace(/^_/, '').replace(/ Hub$/, '').toLowerCase();
      return `[${label}](/${catName})`;
    }
    // Check if target matches an article in current category
    const matchArticle = articles.find((a: any) => 
      a.title === target || a.slug === target || a.slug === encodeURIComponent(target)
    );
    if (matchArticle) {
      return `[${label}](/${currentCategory}/${matchArticle.slug})`;
    }
    // Default: link to search or just bold the text
    return `**${label}**`;
  });
}

const resolvedContent = hubContent ? resolveWikilinks(hubContent, category) : '';
const hubHtml = resolvedContent ? marked.parse(resolvedContent) : '';

// Split hub HTML into sections at <h2> boundaries for chart injection (economy only)
const isEconomy = category === 'economy';
type HubSection = { html: string; chartAfter?: string };
let hubSections: HubSection[] = [];
if (isEconomy && hubHtml) {
  const parts = (hubHtml as string).split(/(?=<h2>)/);
  hubSections = parts.map(part => {
    let chartAfter: string | undefined;
    if (part.includes('從零到英雄')) chartAfter = 'cpi';
    else if (part.includes('矽島的誕生')) chartAfter = 'taiex';
    else if (part.includes('服務經濟')) chartAfter = 'salary';
    else if (part.includes('面向未來')) chartAfter = 'housing';
    return { html: part, chartAfter };
  });
}

// 其他分類（跨分類導航用）
const otherCategories = Object.keys(categoryConfig)
  .filter(cat => cat !== category)
  .slice(0, 5) // 只顯示5個
  .map(cat => ({
    key: cat,
    ...categoryConfig[cat as CategoryKey]
  }));
---

<Layout 
  title={`${categoryInfo.name} - Taiwan.md`}
  description={`${categoryInfo.description} - 台灣知識庫`}
>
  <main class="category-page">
    <!-- Hero Banner -->
    <section class="hero-banner" style={`background: ${categoryInfo.gradient};`}>
      <div class="hero-content">
        <div class="hero-icon">{categoryInfo.icon}</div>
        <h1 class="hero-title">{categoryInfo.name}</h1>
        <p class="hero-description">{categoryInfo.description}</p>
        <div class="hero-stats">
          <span class="stats-badge">📚 {articles.length} 篇文章</span>
        </div>
      </div>
      <div class="hero-decoration"></div>
    </section>

    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">首頁</a>
        <span class="separator">›</span>
        <span class="current">{categoryInfo.name}</span>
      </nav>

      <!-- Hub Content (curated overview) -->
      {hubHtml && (
        <section class="hub-content">
          {isEconomy ? (
            hubSections.map(section => (
              <>
                <div class="hub-prose" set:html={section.html} />
                {section.chartAfter === 'cpi' && (
                  <div class="econ-chart-section">
                    <h3 class="econ-chart-title">📊 消費者物價指數（CPI）</h3>
                    <p class="econ-chart-subtitle">Consumer Price Index（基期 2021=100）1981 - 2025</p>
                    <div class="econ-chart-container" id="cpi-chart">
                      <svg class="econ-svg" data-chart="cpi" width="100%" height="320"></svg>
                      <div class="econ-tooltip"></div>
                    </div>
                    <p class="econ-chart-note">台灣長期維持溫和的物價水準，年均通膨率約 1.5%，遠低於多數已開發國家。</p>
                    <p class="econ-chart-source">資料來源：行政院主計總處</p>
                  </div>
                )}
                {section.chartAfter === 'taiex' && (
                  <div class="econ-chart-section">
                    <h3 class="econ-chart-title">📈 歷年台股加權指數</h3>
                    <p class="econ-chart-subtitle">Taiwan Stock Exchange Weighted Index（TAIEX）1967 - 2025</p>
                    <div class="econ-chart-container" id="taiex-chart">
                      <svg class="econ-svg" data-chart="taiex" width="100%" height="320"></svg>
                      <div class="econ-tooltip"></div>
                    </div>
                    <p class="econ-chart-source">資料來源：臺灣證券交易所（TWSE）歷年收盤價</p>
                  </div>
                )}
                {section.chartAfter === 'salary' && (
                  <div class="econ-chart-section">
                    <h3 class="econ-chart-title">💰 經常性薪資變化</h3>
                    <p class="econ-chart-subtitle">Average Monthly Regular Earnings（NTD）1981 - 2025</p>
                    <div class="econ-chart-container" id="salary-chart">
                      <svg class="econ-svg" data-chart="salary" width="100%" height="320"></svg>
                      <div class="econ-tooltip"></div>
                    </div>
                    <p class="econ-chart-note">2003 年後薪資成長明顯趨緩，扣除物價漲幅後的「實質薪資」幾乎停滯近二十年。</p>
                    <p class="econ-chart-source">資料來源：行政院主計總處 薪資與生產力統計</p>
                  </div>
                )}
                {section.chartAfter === 'housing' && (
                  <div class="econ-chart-section">
                    <h3 class="econ-chart-title">🏠 房價指數走勢</h3>
                    <p class="econ-chart-subtitle">Sinyi Housing Price Index（基期 2016Q1=100）2001 - 2025</p>
                    <div class="econ-chart-container" id="housing-chart">
                      <svg class="econ-svg" data-chart="housing" width="100%" height="320"></svg>
                      <div class="econ-tooltip"></div>
                    </div>
                    <p class="econ-chart-note">2020 年起房價快速攀升，全國房價指數在五年內上漲逾 44%，「居住正義」成為社會核心議題。</p>
                    <p class="econ-chart-source">資料來源：信義房屋不動產企研室</p>
                  </div>
                )}
              </>
            ))
          ) : (
            <div class="hub-prose" set:html={hubHtml} />
          )}
        </section>
      )}

      <!-- Articles Section -->
      <h2 class="articles-heading">📖 延伸閱讀</h2>
      {articles.length > 0 ? (
        <section class="articles-section">
          <div class="articles-grid">
            {articles.map((article, index) => (
              <article class={`article-card ${index === 0 && article.featured ? 'featured-card' : ''}`}>
                <a href={`/${category}/${article.slug}`} class="card-link">
                  <div class="card-image-placeholder" style={`background: ${categoryInfo.gradient};`}>
                    <div class="card-image-icon">{categoryInfo.icon}</div>
                  </div>
                  
                  <div class="card-content">
                    <div class="card-header">
                      <div class="article-meta">
                        {article.status && (
                          <span class="status-tag">{article.status}</span>
                        )}
                        {article.lang && (
                          <span class="lang-tag">{article.lang === 'zh-TW' ? '中文' : 'EN'}</span>
                        )}
                      </div>
                      {article.featured && (
                        <div class="featured-badge">⭐ 精選</div>
                      )}
                    </div>
                    
                    <h3 class="article-title">{article.title}</h3>
                    
                    <p class="article-excerpt">{article.description}</p>
                    
                    <div class="article-info">
                      {article.readingTime && (
                        <span class="info-item">
                          📖 {article.readingTime} 分鐘
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </section>
      ) : (
        <section class="coming-soon">
          <div class="coming-soon-content">
            <div class="coming-soon-icon">{categoryInfo.icon}</div>
            <h2>內容準備中</h2>
            <p>這個分類的文章正在努力製作中，敬請期待！</p>
            <p class="category-desc">未來這裡將會有：{categoryInfo.description}</p>
            
            <div class="action-buttons">
              <a href="/" class="btn-primary">返回首頁</a>
              <a href="https://github.com/frank890417/taiwan-md" target="_blank" class="btn-secondary">
                參與貢獻
              </a>
            </div>
          </div>
        </section>
      )}

      <!-- 探索其他面向 -->
      <section class="explore-more">
        <h2 class="explore-title">探索台灣其他面向</h2>
        <div class="categories-grid">
          {otherCategories.map(cat => (
            <a href={`/${cat.key}`} class="category-card" style={`border-color: ${cat.color}; color: ${cat.color};`}>
              <div class="category-card-icon">{cat.icon}</div>
              <div class="category-card-name">{cat.name}</div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<style define:vars={{ categoryColor: categoryInfo.color, categoryColorLight: categoryInfo.colorLight }}>
