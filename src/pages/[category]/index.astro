{isEconomy && (
  <script define:vars={{ taiexData, cpiData, salaryData, housingData }}>
    document.addEventListener('DOMContentLoaded', () => {
      const ns = 'http://www.w3.org/2000/svg';

      function createChart(cfg) {
        const svg = cfg.svg;
        const tooltip = cfg.tooltip;
        const container = svg.parentElement;
        if (!svg || !tooltip) return;

        const data = cfg.data;
        const color = cfg.color;
        const valueKey = cfg.valueKey || 'value';
        const rect = container.getBoundingClientRect();
        const width = rect.width;
        const height = parseInt(svg.getAttribute('height')) || 320;
        const margin = { top: 20, right: 20, bottom: 36, left: 55 };
        const innerW = width - margin.left - margin.right;
        const innerH = height - margin.top - margin.bottom;

        svg.setAttribute('viewBox', `0 0 ${width} ${height}`);
        svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');

        const minYear = data[0].year;
        const maxYear = data[data.length - 1].year;
        const vals = data.map(d => d[valueKey]);
        const maxVal = Math.max(...vals);
        const minVal = Math.min(...vals);
        const yPad = (maxVal - minVal) * 0.1 || maxVal * 0.1;
        const yMin = Math.max(0, minVal - yPad);
        const yMax = maxVal + yPad;

        const xScale = (year) => margin.left + ((year - minYear) / (maxYear - minYear)) * innerW;
        const yScale = (val) => margin.top + innerH - ((val - yMin) / (yMax - yMin)) * innerH;

        // Gradient
        const defs = document.createElementNS(ns, 'defs');
        const gradId = cfg.id + '-grad';
        const grad = document.createElementNS(ns, 'linearGradient');
        grad.id = gradId;
        grad.setAttribute('x1', '0'); grad.setAttribute('y1', '0');
        grad.setAttribute('x2', '0'); grad.setAttribute('y2', '1');
        const s1 = document.createElementNS(ns, 'stop');
        s1.setAttribute('offset', '0%'); s1.setAttribute('stop-color', color); s1.setAttribute('stop-opacity', '0.25');
        const s2 = document.createElementNS(ns, 'stop');
        s2.setAttribute('offset', '100%'); s2.setAttribute('stop-color', color); s2.setAttribute('stop-opacity', '0.02');
        grad.appendChild(s1); grad.appendChild(s2);
        defs.appendChild(grad); svg.appendChild(defs);

        // Grid lines
        const gridG = document.createElementNS(ns, 'g');
        const tickCount = 5;
        for (let i = 0; i <= tickCount; i++) {
          const val = yMin + (yMax - yMin) * (i / tickCount);
          const y = yScale(val);
          const line = document.createElementNS(ns, 'line');
          line.setAttribute('x1', margin.left); line.setAttribute('x2', width - margin.right);
          line.setAttribute('y1', y); line.setAttribute('y2', y);
          line.setAttribute('stroke', '#e2e8f0'); line.setAttribute('stroke-width', '1');
          gridG.appendChild(line);
          const label = document.createElementNS(ns, 'text');
          label.setAttribute('x', margin.left - 8); label.setAttribute('y', y + 4);
          label.setAttribute('text-anchor', 'end'); label.setAttribute('fill', '#94a3b8');
          label.setAttribute('font-size', '10');
          label.textContent = cfg.yFormat ? cfg.yFormat(val) : Math.round(val).toLocaleString();
          gridG.appendChild(label);
        }
        svg.appendChild(gridG);

        // X-axis
        const xG = document.createElementNS(ns, 'g');
        const yearSpan = maxYear - minYear;
        const step = yearSpan <= 25 ? 5 : 10;
        const startTick = Math.ceil(minYear / step) * step;
        for (let yr = startTick; yr <= maxYear; yr += step) {
          const x = xScale(yr);
          const t = document.createElementNS(ns, 'text');
          t.setAttribute('x', x); t.setAttribute('y', height - margin.bottom + 18);
          t.setAttribute('text-anchor', 'middle'); t.setAttribute('fill', '#94a3b8');
          t.setAttribute('font-size', '10'); t.textContent = yr;
          xG.appendChild(t);
        }
        svg.appendChild(xG);

        // Area
        let areaD = `M ${xScale(data[0].year)} ${yScale(data[0][valueKey])}`;
        for (let i = 1; i < data.length; i++) areaD += ` L ${xScale(data[i].year)} ${yScale(data[i][valueKey])}`;
        areaD += ` L ${xScale(data[data.length - 1].year)} ${yScale(yMin)} L ${xScale(data[0].year)} ${yScale(yMin)} Z`;
        const area = document.createElementNS(ns, 'path');
        area.setAttribute('d', areaD); area.setAttribute('fill', `url(#${gradId})`);
        svg.appendChild(area);

        // Line
        let lineD = `M ${xScale(data[0].year)} ${yScale(data[0][valueKey])}`;
        for (let i = 1; i < data.length; i++) lineD += ` L ${xScale(data[i].year)} ${yScale(data[i][valueKey])}`;
        const linePath = document.createElementNS(ns, 'path');
        linePath.setAttribute('d', lineD); linePath.setAttribute('fill', 'none');
        linePath.setAttribute('stroke', color); linePath.setAttribute('stroke-width', '2.5');
        linePath.setAttribute('stroke-linejoin', 'round');
        svg.appendChild(linePath);

        // Milestones
        data.filter(d => d.milestone).forEach(d => {
          const c = document.createElementNS(ns, 'circle');
          c.setAttribute('cx', xScale(d.year)); c.setAttribute('cy', yScale(d[valueKey]));
          c.setAttribute('r', '3.5'); c.setAttribute('fill', color);
          c.setAttribute('stroke', '#fff'); c.setAttribute('stroke-width', '2');
          svg.appendChild(c);
        });

        // Hover elements
        const hoverG = document.createElementNS(ns, 'g');
        const hLine = document.createElementNS(ns, 'line');
        hLine.setAttribute('y1', margin.top); hLine.setAttribute('y2', height - margin.bottom);
        hLine.setAttribute('stroke', color); hLine.setAttribute('stroke-width', '1');
        hLine.setAttribute('stroke-dasharray', '4,4'); hLine.setAttribute('opacity', '0');
        hoverG.appendChild(hLine);
        const hDot = document.createElementNS(ns, 'circle');
        hDot.setAttribute('r', '5'); hDot.setAttribute('fill', color);
        hDot.setAttribute('stroke', '#fff'); hDot.setAttribute('stroke-width', '2');
        hDot.setAttribute('opacity', '0');
        hoverG.appendChild(hDot);
        svg.appendChild(hoverG);

        const hRect = document.createElementNS(ns, 'rect');
        hRect.setAttribute('x', margin.left); hRect.setAttribute('y', margin.top);
        hRect.setAttribute('width', innerW); hRect.setAttribute('height', innerH);
        hRect.setAttribute('fill', 'transparent'); hRect.style.cursor = 'crosshair';
        svg.appendChild(hRect);

        function findClosest(mouseX) {
          const svgRect = svg.getBoundingClientRect();
          const scaleX = width / svgRect.width;
          const adjX = mouseX * scaleX;
          let closest = data[0], minDist = Infinity;
          data.forEach(d => { const dist = Math.abs(xScale(d.year) - adjX); if (dist < minDist) { minDist = dist; closest = d; } });
          return closest;
        }

        function showTooltip(clientX, clientY) {
          const svgRect = svg.getBoundingClientRect();
          const d = findClosest(clientX - svgRect.left);
          const cx = xScale(d.year), cy = yScale(d[valueKey]);
          hLine.setAttribute('x1', cx); hLine.setAttribute('x2', cx); hLine.setAttribute('opacity', '0.5');
          hDot.setAttribute('cx', cx); hDot.setAttribute('cy', cy); hDot.setAttribute('opacity', '1');
          let html = `<strong>${d.year}</strong><br>${cfg.tooltipLabel}${cfg.tooltipFormat ? cfg.tooltipFormat(d[valueKey]) : d[valueKey].toLocaleString()}`;
          if (d.milestone) html += `<br>📌 ${d.milestone}`;
          tooltip.innerHTML = html; tooltip.style.display = 'block';
          const cRect = container.getBoundingClientRect();
          let tx = clientX - cRect.left + 12, ty = clientY - cRect.top - 10;
          if (tx + 160 > cRect.width) tx -= 170;
          if (ty < 10) ty = 10;
          tooltip.style.left = tx + 'px'; tooltip.style.top = ty + 'px';
        }

        function hideTooltip() {
          hLine.setAttribute('opacity', '0'); hDot.setAttribute('opacity', '0');
          tooltip.style.display = 'none';
        }

        hRect.addEventListener('mousemove', e => showTooltip(e.clientX, e.clientY));
        hRect.addEventListener('mouseleave', hideTooltip);
        hRect.addEventListener('touchmove', e => { e.preventDefault(); showTooltip(e.touches[0].clientX, e.touches[0].clientY); });
        hRect.addEventListener('touchend', hideTooltip);
      }

      // Chart configurations
      const charts = [
        {
          id: 'taiex', data: taiexData, color: '#c2410c', valueKey: 'close',
          tooltipLabel: '加權指數：', tooltipFormat: v => v.toLocaleString(),
          yFormat: v => v >= 1000 ? Math.round(v / 1000) + 'K' : Math.round(v).toString()
        },
        {
          id: 'cpi', data: cpiData, color: '#16a34a', valueKey: 'value',
          tooltipLabel: 'CPI：', tooltipFormat: v => v.toFixed(1),
          yFormat: v => v.toFixed(0)
        },
        {
          id: 'salary', data: salaryData, color: '#2563eb', valueKey: 'value',
          tooltipLabel: '經常性薪資：NT$', tooltipFormat: v => Math.round(v).toLocaleString(),
          yFormat: v => v >= 1000 ? Math.round(v / 1000) + 'K' : Math.round(v).toString()
        },
        {
          id: 'housing', data: housingData, color: '#dc2626', valueKey: 'value',
          tooltipLabel: '房價指數：', tooltipFormat: v => v.toFixed(1),
          yFormat: v => v.toFixed(0)
        }
      ];

      charts.forEach(cfg => {
        const container = document.getElementById(cfg.id + '-chart');
        if (!container) return;
        const svg = container.querySelector('.econ-svg');
        const tooltip = container.querySelector('.econ-tooltip');
        if (svg && tooltip) {
          createChart({ ...cfg, svg, tooltip });
        }
      });
    });
  </script>
)}